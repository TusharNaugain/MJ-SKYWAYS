# MJ Skyways — Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# JWT Secrets (generate strong random strings for production — REQUIRED, no fallback)
JWT_SECRET=replace_with_strong_random_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_another_strong_random_secret

# Default admin password (used only on first seed when admin@mjskyways.com doesn't exist)
DEFAULT_ADMIN_PASSWORD=replace_with_strong_admin_password

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@mjskyways.com
SMTP_PASS=your_email_app_password

# Database (when migrating to MongoDB)
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/mjskyways
